--- a/mojito.c
+++ b/mojito.c
@@ -8,6 +8,7 @@
 #include <poll.h>
 #include <stdio.h>
 #include <stdlib.h>
+#include <errno.h>
 #include <string.h>
 #include <unistd.h>
 
@@ -241,7 +242,7 @@ run(void)
   fds[0].fd = wl_display_get_fd(display);
-  fds[0].events = POLLIN;
+  fds[0].events = POLLIN | POLLOUT;
   fds[1].fd = STDIN_FILENO;
   fds[1].events = POLLIN;
 
@@ -249,7 +250,13 @@ run(void)
     if (wl_display_flush(display) == -1) {
-      break;
+      if (errno != EAGAIN) {
+        break;
+      }
+      /* output buffer full, wait for writability */
+      fds[0].events = POLLIN | POLLOUT;
+    } else {
+      /* flush succeeded, stop watching for writability */
+      fds[0].events = POLLIN;
     }
 
     if (poll(fds, 2, -1) == -1) {
@@ -258,6 +265,11 @@ run(void)
 
     if (fds[0].revents & POLLIN) {
       if (wl_display_dispatch(display) == -1) {
         break;
       }
     }
+
+    if (fds[0].revents & POLLOUT) {
+      /* socket writable again, flush pending data */
+      wl_display_flush(display);
+    }
